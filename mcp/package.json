{
	"name": "@microsoft/atlas-mcp",
	"version": "0.1.0",
	"description": "MCP server exposing Atlas Design System resources to AI agents",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"atlas-mcp": "./dist/index.js"
	},
	"engines": {
		"node": "^24.0.0",
		"npm": "^11.0.0"
	},
	"scripts": {
		"build": "wireit",
		"build:data": "wireit",
		"start": "node dist/index.js",
		"dev": "tsc --watch",
		"lint": "eslint src --ext .ts",
		"prepublishOnly": "npm run build"
	},
	"wireit": {
		"build": {
			"command": "tsc",
			"dependencies": [
				"build:data"
			],
			"files": [
				"src/**/*.ts",
				"tsconfig.json"
			],
			"output": [
				"dist/**"
			]
		},
		"build:data": {
			"command": "node scripts/build-data.js",
			"dependencies": [
				"../css:class-names",
				"../css:tokens"
			],
			"files": [
				"scripts/build-data.js",
				"../site/src/components/*.md",
				"../site/src/atomics/*.md",
				"../site/src/patterns/*.md",
				"../css/dist/class-names.json",
				"../css/dist/tokens.json"
			],
			"output": [
				"data/atlas-data.json"
			]
		}
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.0",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@types/node": "^24.0.0",
		"@typescript-eslint/eslint-plugin": "^5.62.0",
		"@typescript-eslint/parser": "^5.62.0",
		"eslint": "^8.43.0",
		"front-matter": "^4.0.2",
		"typescript": "^5.1.5",
		"wireit": "0.14.9"
	},
	"files": [
		"dist",
		"data"
	],
	"keywords": [
		"mcp",
		"model-context-protocol",
		"atlas",
		"design-system",
		"css"
	],
	"author": "Microsoft Corporation",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/microsoft/atlas-design"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org"
	}
}
