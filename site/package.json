{
	"name": "@microsoft/atlas-site",
	"version": "0.67.0",
	"license": "MIT",
	"private": true,
	"engines": {
		"node": "24.11.1",
		"npm": "11.6.2"
	},
	"scripts": {
		"prebuild": "npm run build:assets",
		"prestart": "npm run build:assets",
		"build:scss": "sass src/scaffold/index.scss dist/scaffold/index.css --load-path=../node_modules --quiet-deps && sass src/scaffold/styles/homepage.scss dist/scaffold/styles/homepage.css --load-path=../node_modules --quiet-deps",
		"build:ts": "esbuild src/scaffold/index.ts --bundle --outfile=dist/scaffold/index.js --format=esm --platform=browser",
		"build:assets": "npm run build:scss && npm run build:ts",
		"start": "npm run build:assets && eleventy --serve --port=1111",
		"build": "eleventy",
		"toc": "node toc.js",
		"type-check": "tsc --noEmit",
		"prelint": "npm run type-check",
		"lint": "eslint . --ext .ts",
		"lint-fix": "eslint . --ext .ts --fix"
	},
	"devDependencies": {
		"@11ty/eleventy": "^3.1.2",
		"@11ty/eleventy-navigation": "^1.0.5",
		"@microsoft/atlas-css": "4.3.0",
		"@microsoft/atlas-js": "^1.15.0",
		"@typescript-eslint/eslint-plugin": "^5.60.1",
		"@typescript-eslint/parser": "^5.60.1",
		"cross-env": "^7.0.3",
		"esbuild": "^0.25.12",
		"eslint": "^8.43.0",
		"eslint-config-prettier": "^8.8.0",
		"eslint-plugin-import": "^2.27.5",
		"front-matter": "^4.0.2",
		"fs-extra": "^11.1.1",
		"highlight.js": "^11.11.1",
		"marked": "^5.1.2",
		"sass": "^1.97.3",
		"typescript": "^5.1.5"
	}
}
